Package: nas-web
Architecture: any
Depends: ${shlibs:Depends}, ${misc:Depends},
 libuv1 (>= 1.40),
 libssl3,
 zlib1g,
 libbrotli1,
 liblua5.4-0,
 libnghttp2-14
Recommends:
