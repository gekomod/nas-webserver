#!/usr/bin/make -f
export DH_VERBOSE = 1
export DEB_BUILD_MAINT_OPTIONS = hardening=+all

%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_BUILD_TYPE=Release \
		-DWITH_LUA=ON \
		-DWITH_NGHTTP2=ON \
		-DWITH_BROTLI=ON \
		-DWITH_V8=OFF \
		-DWITH_QUICHE=OFF

override_dh_auto_test:
	# skip unit tests during package build
	: no-op
